BOSSRAID_IMAGE=ghcr.io/your-org/boss-raid:latest
# Point callbacks at the active Boss Raid control plane.
# The current public path is the Pages proxy in front of the Phala-backed API:
# https://bossraid-web.pages.dev/api
BOSSRAID_CALLBACK_BASE=https://<bossraid-control-plane-host>/api

# Provider worker auth must stay enabled in unattended deploys.
BOSSRAID_PROVIDER_A_TOKEN=replace-with-provider-a-token
BOSSRAID_PROVIDER_B_TOKEN=replace-with-provider-b-token
BOSSRAID_PROVIDER_C_TOKEN=replace-with-provider-c-token

# Provider fleet identity and specialization metadata.
BOSSRAID_PROVIDER_A_ID=dottie
BOSSRAID_PROVIDER_A_NAME=Dottie
BOSSRAID_PROVIDER_A_MODE=pixel_art
BOSSRAID_PROVIDER_A_INSTRUCTIONS=Specialize in pixel-art asset packs, spritesheets, UI frames, and compact retro palettes.
BOSSRAID_PROVIDER_A_MODEL_API_KEY=replace-with-dottie-model-key
BOSSRAID_PROVIDER_A_MODEL_API_BASE=https://api.venice.ai/api/v1
BOSSRAID_PROVIDER_A_MODEL=minimax-m27

BOSSRAID_PROVIDER_B_ID=riko
BOSSRAID_PROVIDER_B_NAME=Riko
BOSSRAID_PROVIDER_B_MODE=remotion
BOSSRAID_PROVIDER_B_INSTRUCTIONS=Specialize in game marketing videos, teaser hooks, launch copy, and Remotion-ready promo bundles.
BOSSRAID_PROVIDER_B_MODEL_API_KEY=replace-with-riko-model-key
BOSSRAID_PROVIDER_B_MODEL_API_BASE=https://api.venice.ai/api/v1
BOSSRAID_PROVIDER_B_MODEL=minimax-m27

BOSSRAID_PROVIDER_C_ID=gamma
BOSSRAID_PROVIDER_C_NAME=Gamma
BOSSRAID_PROVIDER_C_MODE=gbstudio
BOSSRAID_PROVIDER_C_INSTRUCTIONS=Specialize in small game-development slices, gameplay logic, and minimal repo patches that keep one clear hook.
BOSSRAID_PROVIDER_C_MODEL_API_KEY=replace-with-gamma-model-key
BOSSRAID_PROVIDER_C_MODEL_API_BASE=https://api.venice.ai/api/v1
BOSSRAID_PROVIDER_C_MODEL=minimax-m27
