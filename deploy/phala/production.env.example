# Production configuration reference for Boss Raid on Phala
# Copy this file to .env (which is gitignored) and fill in real values.
# DO NOT commit real keys or secrets.

# =============================================================================
# REQUIRED FOR PRODUCTION
# =============================================================================

BOSSRAID_X402_PAY_TO=0x3bd7717267c6A2D29F07Da83D59155Ac6cD80A69
BOSSRAID_X402_ENABLED=true
BOSSRAID_X402_NETWORK=eip155:8453
BOSSRAID_X402_ASSET=usdc
BOSSRAID_X402_ASSET_NAME=USDC
BOSSRAID_X402_FACILITATOR_URL=

BOSSRAID_ADMIN_TOKEN=<replace-with-long-random-admin-token>
BOSSRAID_REGISTRY_TOKEN=<replace-with-long-random-registry-token>

# =============================================================================
# ERC-8004 IDENTITY (from ACP registration)
# =============================================================================

BOSSRAID_ERC8004_AGENT_ID=<from-ACP-capture-sheet>
BOSSRAID_ERC8004_OPERATOR_WALLET=<from-ACP-capture-sheet>
BOSSRAID_ERC8004_REGISTRATION_TX=<from-ACP-capture-sheet>
BOSSRAID_ERC8004_IDENTITY_REGISTRY=<from-ACP-capture-sheet>

# =============================================================================
# ERC-8183 SETTLEMENT (from ACP or manual contract deploy)
# =============================================================================

BOSSRAID_SETTLEMENT_MODE=onchain
BOSSRAID_RPC_URL=https://mainnet.base.org
BOSSRAID_CHAIN_ID=8453
BOSSRAID_REGISTRY_ADDRESS=<deployed-raid-registry-address>
BOSSRAID_ESCROW_ADDRESS=<deployed-bossjob-escrow-address>
BOSSRAID_TOKEN_ADDRESS=0x833589fCD6eDb6B08d2E354A1d9441DV2D74E4a5
BOSSRAID_CLIENT_PRIVATE_KEY=<wallet-with-usdc-for-gas-and-escrow-funding>
BOSSRAID_EVALUATOR_ADDRESS=<evaluator-wallet-address>
BOSSRAID_PROVIDER_ADDRESS_MAP_JSON=<provider-id-to-address-map-json>