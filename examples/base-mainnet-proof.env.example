# Base mainnet proof lane for the final Synthesis demo.
# Keep real secrets in your local env manager, not in git.

# Base / x402
BOSSRAID_CHAIN_ID=8453
BOSSRAID_RPC_URL=https://base-mainnet.g.alchemy.com/v2/<key>
# Public write routes are paid by default. Set BOSSRAID_X402_ENABLED=false only if
# you intentionally want unpaid private ingress.
BOSSRAID_X402_NETWORK=eip155:8453
BOSSRAID_X402_ASSET=usdc
BOSSRAID_X402_PAY_TO=0xYOUR_X402_RECEIVE_ADDRESS

# Optional facilitator configuration
# PAYAI_API_KEY_ID=...
# PAYAI_API_KEY_SECRET=...
# or
# CDP_API_KEY_ID=...
# CDP_API_KEY_SECRET=...

# ERC-8183-aligned settlement
BOSSRAID_SETTLEMENT_MODE=onchain
BOSSRAID_REGISTRY_ADDRESS=0xYOUR_RAID_REGISTRY
BOSSRAID_ESCROW_ADDRESS=0xYOUR_JOB_ESCROW
BOSSRAID_TOKEN_ADDRESS=0xYOUR_USDC_OR_SETTLEMENT_TOKEN
BOSSRAID_CLIENT_PRIVATE_KEY=0xYOUR_SETTLEMENT_CLIENT_PRIVATE_KEY
BOSSRAID_EVALUATOR_ADDRESS=0xYOUR_EVALUATOR_ADDRESS
BOSSRAID_PROVIDER_ADDRESS_MAP_JSON='{"dottie":"0xYOUR_PROVIDER_A","riko":"0xYOUR_PROVIDER_B","gamma":"0xYOUR_PROVIDER_C"}'

# Mercenary ERC-8004 proof surface
# If you anchor registration in Virtuals ACP, use the ERC-8004 references
# produced by ACP registration sync for these values.
BOSSRAID_ERC8004_AGENT_ID=YOUR_MERCENARY_AGENT_ID
BOSSRAID_ERC8004_OPERATOR_WALLET=0xYOUR_MERCENARY_OPERATOR_OR_AGENT_WALLET
BOSSRAID_ERC8004_REGISTRATION_TX=0xYOUR_MERCENARY_ERC8004_REGISTRATION_TX
BOSSRAID_ERC8004_IDENTITY_REGISTRY=0xYOUR_ERC8004_IDENTITY_REGISTRY
# Optional, if the chosen flow exposes them:
# BOSSRAID_ERC8004_REPUTATION_REGISTRY=0xYOUR_ERC8004_REPUTATION_REGISTRY
# BOSSRAID_ERC8004_VALIDATION_REGISTRY=0xYOUR_ERC8004_VALIDATION_REGISTRY
# BOSSRAID_ERC8004_VALIDATION_TXS=0xVAL1,0xVAL2
