  },
  "dependencies": {
    "@bossraid/api-contracts": "workspace:*",
    "@bossraid/orchestrator": "workspace:*",
    "@bossraid/provider-registry": "workspace:*",
    "@bossraid/provider-sdk": "workspace:*",
    "@bossraid/sandbox-runner": "workspace:*",
    "@payai/facilitator": "^2.3.4",
    "fastify": "^5.2.1",
    "viem": "^2.47.5"
