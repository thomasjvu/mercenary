{
  "name": "boss-raid",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "acp-seller:docker:build": "node scripts/build-acp-seller-image.mjs",
    "acp-seller:env:export": "node scripts/export-acp-seller-env.mjs",
    "build": "turbo run build",
    "build:video": "pnpm --filter @bossraid/video build",
    "check": "turbo run check",
    "dev": "node scripts/dev-stack.mjs",
    "dev:api": "node scripts/dev-api.mjs",
    "dev:evaluator": "pnpm --filter @bossraid/evaluator dev",
    "dev:mcp": "node scripts/dev-mcp.mjs",
    "dev:orchestrator": "pnpm --filter @bossraid/orchestrator dev",
    "dev:ops": "pnpm --filter @bossraid/ops dev",
    "dev:provider": "pnpm --filter @bossraid/provider-agent dev",
    "dev:providers": "node scripts/dev-providers.mjs",
    "dev:video": "pnpm --filter @bossraid/video dev",
    "dev:web": "pnpm --filter @bossraid/web dev",
    "deploy:web:cloudflare": "node scripts/deploy-web-cloudflare.mjs",
    "demo:rehearse": "node scripts/demo-rehearse.mjs",
    "docker:build": "node scripts/docker-build.mjs",
    "docker:down": "node scripts/docker-compose.mjs down",
    "docker:up": "node scripts/docker-compose.mjs up --build",
    "eigencompute:build": "docker build --platform linux/amd64 -f Dockerfile.eigencompute -t bossraid-eigencompute:local .",
    "eigencompute:build-job": "docker build --platform linux/amd64 -f Dockerfile.eigencompute --target evaluator-job -t bossraid-evaluator-job:eigencompute-local .",
    "export:proof-bundle": "TSX_TSCONFIG_PATH=tsconfig.base.json node --import tsx scripts/export-proof-bundle.ts",
    "game-raid:build-payload": "node scripts/build-game-raid-payload.mjs",
    "render:video": "pnpm --filter @bossraid/video render",
    "serve:gateway": "node scripts/serve-gateway.mjs",
    "test:unit": "turbo run test",
    "test:evaluator:e2e": "node scripts/test-evaluator-e2e.mjs",
    "test:game-raid:e2e": "node scripts/test-game-raid-e2e.mjs",
    "test:private-game-raid:e2e": "node scripts/test-private-game-raid-e2e.mjs",
    "test:strict-private:e2e": "node scripts/test-strict-private-raid-e2e.mjs",
    "test:mcp:e2e": "pnpm --filter @bossraid/mcp-server test:e2e",
    "test:x402:e2e": "node scripts/test-x402-e2e.mjs",
    "verify:attestation": "node scripts/verify-attestation.mjs",
    "settle:raid": "pnpm --filter @bossraid/orchestrator settle",
    "generate:settlement-keys": "node scripts/generate-settlement-keys.mjs",
    "bootstrap:settlement": "node scripts/bootstrap-settlement.mjs",
    "deploy:contracts": "pnpm build && pnpm --filter @bossraid/contracts run deploy",
    "bootstrap:settlement-env": "pnpm build && pnpm --filter @bossraid/contracts run bootstrap:settlement-env",
    "bootstrap:onchain": "pnpm build && pnpm --filter @bossraid/contracts run bootstrap:onchain"
  },
  "devDependencies": {
    "@payai/facilitator": "^2.3.4",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@x402/evm": "^2.7.0",
    "@x402/fetch": "^2.7.0",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "viem": "^2.47.5"
  }
}
